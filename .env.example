# Anypoint Platform Connected App
# Required scopes: Manage APIs, View APIs, View Organization, View Environment,
#                  Manage Flex Gateways, Read Applications
ANYPOINT_CLIENT_ID="your-connected-app-client-id"
ANYPOINT_CLIENT_SECRET="your-connected-app-client-secret"
ANYPOINT_ORG_ID="your-anypoint-org-id"
ANYPOINT_ENV_ID="your-anypoint-environment-id"
ANYPOINT_HOST="anypoint.mulesoft.com"  # eu1.anypoint.mulesoft.com | ca1... | jp1...

# CloudHub 2.0 — pre-provisioned Managed Flex Gateway
FLEX_GW_TARGET_ID="your-private-space-target-id"
FLEX_GW_NAME="your-flex-gateway-name"

# Keycloak JWT Validation
KEYCLOAK_JWKS_URL="https://your-keycloak/realms/your-realm/protocol/openid-connect/certs"
KEYCLOAK_AUDIENCE="your-jwt-audience"

# Local development only — bypasses Istio ingress discovery
ISTIO_INGRESS_HOST=""
